<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/label_operating_mode"
        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBeReceiver"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="@string/btn_be_receiver"
            app:icon="@android:drawable/stat_sys_download_done"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBeSender"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="@string/btn_be_sender"
            app:icon="@android:drawable/stat_sys_upload_done"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendTest"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="32dp"
        android:text="@string/btn_send_test"
        app:icon="@android:drawable/ic_menu_send"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent"
        app:strokeColor="?attr/colorOutline" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForgetDevice"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="-20dp"
        android:layout_marginBottom="32dp"
        android:text="@string/btn_forget_device"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent"
        app:strokeColor="?attr/colorOutline" />
</LinearLayout>
