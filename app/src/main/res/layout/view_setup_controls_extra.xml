<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBatteryOptimization"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="start|center_vertical"
        android:text="@string/btn_battery_optimization"
        android:textColor="?attr/colorOnSurface"
        app:icon="@android:drawable/ic_lock_power_off"
        app:iconTint="?attr/colorOnSurface"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectApps"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="@string/btn_select_apps"
        app:icon="@android:drawable/ic_menu_agenda"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.SmallComponent" />
</merge>
